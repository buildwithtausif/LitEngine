{
  "redirects": [
    {
      "source": "/",
      "destination": "/dashboard/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/dashboard/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/dashboard/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}